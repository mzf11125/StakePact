# Solana wallet address to receive x402 payments
SVM_ADDRESS=

# Price per request in USD (default: 0.001)
PAYMENT_USD=0.001

# Server port (default: 3402)
PORT=3402

# Solana RPC URL (default: devnet)
RPC_URL=https://api.devnet.solana.com

# Agent private key (Base58) — for client.ts
SVM_PRIVATE_KEY=

# AgentBond program ID
PROGRAM_ID=82CcH55vDyFmZQC96gEPPEcWFSidKvBm92zdo7e8Xu13

# x402 server URL — for client.ts
X402_SERVER_URL=http://localhost:3402
